{
    "type": "tabs",
    "items": {
        "main": {
            "type": "panel",
            "label": "settings_label",
            "items": {
                "logo": {
                    "type": "staticImage",
                    "src": "hausbusde.png",
                    "xs": 12,
                    "sm": 2,
                    "md": 2,
                    "lg": 2,
                    "xl": 2,
                    "styles": {
                        "width": "100%",
                        "maxWidth": "100px"
                    }
                },
                "title": {
                    "type": "staticText",
                    "text": "config_free_text",
                    "xs": 12,
                    "sm": 8,
                    "md": 8,
                    "lg": 8,
                    "xl": 8,
                    "styles": {
                        "textAlign": "center",
                        "fontWeight": "bold",
                        "fontSize": "1.2rem",
                        "marginTop": "20px"
                    }
                },
                "thumb": {
                    "type": "staticImage",
                    "src": "daumen.png",
                    "xs": 12,
                    "sm": 2,
                    "md": 2,
                    "lg": 2,
                    "xl": 2,
                    "styles": {
                        "width": "100%",
                        "maxWidth": "80px",
                        "float": "right"
                    }
                },
                "_divider": {
                    "type": "divider",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12
                },
                "description": {
                    "type": "staticLink",
                    "text": "info_documentation_text",
                    "button": false,
                    "label": "www.haus-bus.de/iobroker",
                    "href": "https://www.haus-bus.de/iobroker",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "styles": {
                        "marginTop": "20px"
                    }
                }
            }
        }
    }
}
